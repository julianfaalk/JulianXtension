{
  "manifest_version": 3,
  "name": "X Themes by Julian",
  "description": "Wende eines aus 12 kuratierten Themes auf X.com (Twitter) an. Inspired by X-Dim Mode.",
  "version": "0.5.3",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Themes"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
