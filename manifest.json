{
  "manifest_version": 3,
  "name": "Julians Tweaks",
  "description": "Annoyance-Killer für X, YouTube, Google, LinkedIn, Reddit, GitHub & Instagram unter einem Popup.",
  "version": "1.4.0",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://pro.x.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*",
    "https://www.google.com/*",
    "https://www.google.de/*",
    "https://www.google.co.uk/*",
    "https://www.google.at/*",
    "https://www.google.ch/*",
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*",
    "https://new.reddit.com/*",
    "https://github.com/*",
    "https://gist.github.com/*",
    "https://www.instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Julians Tweaks",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://pro.x.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*"
      ],
      "css": ["preload.css"],
      "js": ["xdim.js", "content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.de/search*",
        "https://www.google.co.uk/search*",
        "https://www.google.at/search*",
        "https://www.google.ch/search*"
      ],
      "js": ["google.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["linkedin.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://new.reddit.com/*"
      ],
      "js": ["reddit.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://github.com/*",
        "https://gist.github.com/*"
      ],
      "js": ["github.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": ["instagram.js"],
      "run_at": "document_start"
    }
  ]
}
