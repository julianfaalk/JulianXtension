{
  "manifest_version": 3,
  "name": "Julians Tweaks",
  "description": "X.com Themes + YouTube Shorts ausblenden. Mehrere App-Tweaks unter einer Extension.",
  "version": "0.6.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Julians Tweaks"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "youtube.js"
      ],
      "run_at": "document_start"
    }
  ]
}
